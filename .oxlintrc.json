{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["nextjs", "react", "typescript", "oxc"],
  "env": {
    "browser": true,
    "es2022": true
  },
  "settings": {
    "react": {
      "version": "19"
    }
  },
  "rules": {
    "no-console": "off"
  },
  "ignorePatterns": ["node_modules/", ".next/", "out/", "build/"]
}
